meta {
  name: Score Single Job
  type: http
  seq: 5
}

post {
  url: {{base_url}}/jobs/1/score
  body: json
  auth: none
}

body:json {
  {
    "resume_id": 1
  }
}

script:post-response {
  if (res.status === 200 && res.body && res.body.task_id) {
    bru.setEnvVar("task_id", res.body.task_id);
  }
}